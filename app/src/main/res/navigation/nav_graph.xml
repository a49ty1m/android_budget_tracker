<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.smilo.budgettracker.ui.HomeFragment"
        android:label="Home" >
        <action
            android:id="@+id/action_homeFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_homeFragment_to_addExpenseFragment"
            app:destination="@id/addExpenseFragment" />
        <action
            android:id="@+id/action_homeFragment_to_accountFragment"
            app:destination="@id/accountFragment" />
    </fragment>

    <fragment
        android:id="@+id/addExpenseFragment"
        android:name="com.smilo.budgettracker.ui.AddExpenseFragment"
        android:label="Add Transaction" >
        <argument
            android:name="initialType"
            app:argType="string"
            android:defaultValue="Expense" />
        <action
            android:id="@+id/action_addExpenseFragment_to_accountFragment"
            app:destination="@id/accountFragment" />
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.smilo.budgettracker.ui.HistoryFragment"
        android:label="History" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.smilo.budgettracker.ui.SettingsFragment"
        android:label="Settings" />

    <fragment
        android:id="@+id/categoryFragment"
        android:name="com.smilo.budgettracker.ui.CategoryFragment"
        android:label="Manage Categories" >
        <action
            android:id="@+id/action_categoryFragment_to_accountFragment"
            app:destination="@id/accountFragment" />
    </fragment>

    <fragment
        android:id="@+id/accountFragment"
        android:name="com.smilo.budgettracker.ui.AccountFragment"
        android:label="Accounts &amp; Savings" />

</navigation>
