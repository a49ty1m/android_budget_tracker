<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.App.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/chip_bg_color</item>
        <item name="android:textColor">@color/chip_text_color</item>
        <item name="chipIconVisible">false</item>
        <item name="chipStrokeColor">@color/bg_surface</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="rippleColor">@color/accent_glow</item>
    </style>

    <style name="Widget.App.ToggleButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/toggle_text_color</item>
        <item name="backgroundTint">@color/toggle_bg_color</item>
        <item name="strokeColor">@color/bg_card</item>
    </style>

    <style name="CustomCalendarView" parent="ThemeOverlay.MaterialComponents.Dark">
        <item name="colorAccent">@color/accent_amber</item>
        <item name="android:colorAccent">@color/accent_amber</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
</resources>
