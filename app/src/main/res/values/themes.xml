<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BudgetTracker" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/accent_amber</item>
        <item name="colorPrimaryVariant">@color/accent_gold</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorSecondaryVariant">@color/accent_amber</item>
        <item name="colorOnSecondary">@color/bg_dark</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <!-- Customize your theme here. -->
        <item name="colorError">@android:color/holo_red_light</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <item name="materialAlertDialogTheme">@style/AppTheme.AlertDialog</item>
    </style>

    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_amber</item>
        <item name="colorPrimaryVariant">@color/accent_gold</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="materialAlertDialogTheme">@style/AppTheme.AlertDialog</item>
    </style>

    <style name="AppTheme.AlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.App.MediumComponent</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.App.Button.TextButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.App.Button.TextButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.App.Button.TextButton</item>
    </style>

    <style name="ShapeAppearance.App.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Widget.App.Button.TextButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/accent_amber</item>
        <item name="rippleColor">@color/accent_gold</item>
    </style>
</resources>
