<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_add_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Entry"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btn_edit_categories"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Edit Categories"
        android:src="@android:drawable/ic_menu_edit"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_secondary" />

    <!-- Type Toggle -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@+id/btn_type_expense"
        app:layout_constraintTop_toBottomOf="@id/tv_add_title">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_type_expense"
            style="@style/Widget.App.ToggleButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/label_spent"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_type_income"
            style="@style/Widget.App.ToggleButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/label_gained"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_type_saving"
            style="@style/Widget.App.ToggleButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Saving"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_type_account"
            style="@style/Widget.App.ToggleButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Account"
            android:textAllCaps="false" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Amount Input -->
    <LinearLayout
        android:id="@+id/ll_amount_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/toggle_type">

        <TextView
            android:id="@+id/tv_currency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹"
            android:textColor="@color/accent_amber"
            android:textSize="40sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@null"
            android:hint="0"
            android:inputType="numberDecimal"
            android:minWidth="100dp"
            android:padding="8dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="56sp"
            android:textStyle="bold"
            android:importantForAutofill="no">
            <requestFocus />
        </EditText>
    </LinearLayout>

    <!-- Categories -->
<TextView
        android:id="@+id/tv_acc_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Account"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_amount_container" />

    <HorizontalScrollView
        android:id="@+id/hsv_accounts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tv_acc_label">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cg_accounts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true" />
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tv_cat_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Category"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hsv_accounts" />

    <HorizontalScrollView
        android:id="@+id/hsv_categories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tv_cat_label">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cg_categories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="false">
            <!-- Dynamic Chips -->
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Date and Time Picker -->
    <LinearLayout
        android:id="@+id/ll_datetime_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/hsv_categories">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_date"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Date"
            android:textColor="@color/text_primary"
            app:icon="@android:drawable/ic_menu_my_calendar"
            app:iconTint="@color/accent_amber" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_time"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Time"
            android:textColor="@color/text_primary"
            app:icon="@android:drawable/ic_menu_recent_history"
            app:iconTint="@color/accent_amber" />
    </LinearLayout>

    <!-- Note -->
    <EditText
        android:id="@+id/et_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_note_input"
        android:hint="Add a note..."
        android:padding="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:textSize="16sp"
        android:importantForAutofill="no"
        app:layout_constraintTop_toBottomOf="@id/ll_datetime_container" />

    <!-- CTA -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="24dp"
        android:text="Done"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/accent_amber"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
